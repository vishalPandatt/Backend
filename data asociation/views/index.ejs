<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-5">Create Account</h3>
        <form action="/register" method="post" class="flex flex-col gap-3 max-w-sm">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700" type="text" placeholder="Username" name="username">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700" type="text" placeholder="Name" name="name">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700" type="text" placeholder="Age" name="age">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700" type="email" placeholder="Email" name="email">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700" type="password" placeholder="Password" name="password">
            <input class="px-3 py-2 bg-blue-500 text-white rounded-md cursor-pointer" type="submit" value="Create Account">
        </form>
    </div>
</body>
</html>