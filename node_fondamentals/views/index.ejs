<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="./style.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>Status Page</title>
 <style>
     * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #0a0e17;
    color: #e2e8f0;
    min-height: 100vh;
    padding: 40px 20px;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 40px;
  }

  .header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .header h1 .pulse {
    width: 14px;
    height: 14px;
    background: #22c55e;
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6); }
    50% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
  }

  .status-card {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .card-header h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #f1f5f9;
  }

  .overall-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #22c55e;
    cursor: pointer;
    transition: all 0.3s;
  }

  .overall-status:hover {
    background: rgba(34, 197, 94, 0.2);
  }

  .overall-status .dot {
    width: 10px;
    height: 10px;
    background: #22c55e;
    border-radius: 50%;
  }

  .service-row {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid #1e293b;
    transition: all 0.3s;
  }

  .service-row:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .service-row:hover {
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
    padding: 12px 16px;
    margin-left: -16px;
    margin-right: -16px;
  }

  .service-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    cursor: pointer;
  }

  .service-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: #f8fafc;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .service-name .icon {
    font-size: 1.2rem;
  }

  .service-uptime {
    font-size: 0.95rem;
    font-weight: 500;
    color: #22c55e;
  }

  .service-uptime.warning {
    color: #f59e0b;
  }

  .service-uptime.danger {
    color: #ef4444;
  }

  .bars-container {
    display: flex;
    gap: 2px;
    height: 48px;
    align-items: flex-end;
    margin-bottom: 8px;
  }

  .bar {
    flex: 1;
    min-width: 4px;
    max-width: 12px;
    height: 100%;
    border-radius: 3px 3px 2px 2px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }

  .bar.operational {
    background: #22c55e;
  }

  .bar.degraded {
    background: #f59e0b;
  }

  .bar.down {
    background: #ef4444;
  }

  .bar:hover {
    transform: scaleY(1.15);
    filter: brightness(1.3);
    z-index: 2;
  }

  .bar.highlight {
    transform: scaleY(1.2);
    filter: brightness(1.4);
    z-index: 3;
    box-shadow: 0 0 8px rgba(255,255,255,0.3);
  }

  .bar.dimmed {
    opacity: 0.3;
  }

  .time-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #64748b;
  }

  .legend {
    display: flex;
    gap: 24px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #1e293b;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #94a3b8;
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 6px;
    transition: all 0.2s;
    user-select: none;
  }

  .legend-item:hover {
    background: rgba(255,255,255,0.05);
    color: #e2e8f0;
  }

  .legend-item.active {
    background: rgba(255,255,255,0.08);
    color: #e2e8f0;
  }

  .legend-item.disabled {
    opacity: 0.4;
  }

  .legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 3px;
  }

  .legend-dot.operational { background: #22c55e; }
  .legend-dot.degraded { background: #f59e0b; }
  .legend-dot.down { background: #ef4444; }

  /* Tooltip */
  .tooltip {
    position: fixed;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 0.82rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 1000;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    max-width: 240px;
  }

  .tooltip.visible {
    opacity: 1;
  }

  .tooltip .tt-time {
    color: #94a3b8;
    font-size: 0.75rem;
    margin-bottom: 4px;
  }

  .tooltip .tt-status {
    font-weight: 600;
    margin-bottom: 2px;
  }

  .tooltip .tt-status.operational { color: #22c55e; }
  .tooltip .tt-status.degraded { color: #f59e0b; }
  .tooltip .tt-status.down { color: #ef4444; }

  .tooltip .tt-duration {
    color: #64748b;
    font-size: 0.75rem;
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .modal-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .modal {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 16px;
    padding: 32px;
    max-width: 500px;
    width: 90%;
    transform: scale(0.9);
    transition: transform 0.3s;
  }

  .modal-overlay.visible .modal {
    transform: scale(1);
  }

  .modal h3 {
    font-size: 1.2rem;
    margin-bottom: 8px;
    color: #f8fafc;
  }

  .modal .modal-time {
    color: #64748b;
    font-size: 0.85rem;
    margin-bottom: 16px;
  }

  .modal .modal-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .modal .modal-status-badge.operational {
    background: rgba(34,197,94,0.15);
    color: #22c55e;
  }

  .modal .modal-status-badge.degraded {
    background: rgba(245,158,11,0.15);
    color: #f59e0b;
  }

  .modal .modal-status-badge.down {
    background: rgba(239,68,68,0.15);
    color: #ef4444;
  }

  .modal p {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .modal-close {
    background: #1e293b;
    color: #e2e8f0;
    border: none;
    padding: 10px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .modal-close:hover {
    background: #334155;
  }

  /* Filter controls */
  .filter-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid #334155;
    background: transparent;
    color: #94a3b8;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: #475569;
    color: #e2e8f0;
  }

  .filter-btn.active {
    background: #22c55e;
    border-color: #22c55e;
    color: #fff;
  }

  .filter-btn.active.warning-filter {
    background: #f59e0b;
    border-color: #f59e0b;
  }

  .filter-btn.active.danger-filter {
    background: #ef4444;
    border-color: #ef4444;
  }

  /* Incident banner */
  .incident-banner {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 10px;
    padding: 14px 20px;
    margin-bottom: 24px;
    display: none;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: #fca5a5;
    animation: slideDown 0.3s ease;
  }

  .incident-banner.visible {
    display: flex;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .incident-banner .close-banner {
    margin-left: auto;
    background: none;
    border: none;
    color: #fca5a5;
    cursor: pointer;
    font-size: 1.2rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .header h1 { font-size: 1.4rem; }
    .status-card { padding: 20px; }
    .bars-container { height: 36px; }
    .bar { min-width: 3px; }
  }
    </style>
  </head>

<body>

<div class="container">
  <div class="header">
    <h1><span class="pulse"></span> All services are online.</h1>
  </div>

  <div class="status-card">
    <div class="card-header">
      <h2>Status by service</h2>
      <div class="overall-status" id="overallStatus">
        <span class="dot"></span>
        <span id="overallText">Operational</span>
      </div>
    </div>

    <div class="incident-banner" id="incidentBanner">
      ️ <span id="incidentText">Showing only incidents</span>
      <button class="close-banner" onclick="clearFilter()">✕</button>
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all" onclick="setFilter('all')">All</button>
      <button class="filter-btn" data-filter="operational" onclick="setFilter('operational')">Operational</button>
      <button class="filter-btn warning-filter" data-filter="degraded" onclick="setFilter('degraded')">Degraded</button>
      <button class="filter-btn danger-filter" data-filter="down" onclick="setFilter('down')">Down</button>
    </div>

    <div id="servicesContainer"></div>

    <div class="legend">
      <div class="legend-item active" data-legend="operational" onclick="toggleLegend('operational')">
        <span class="legend-dot operational"></span> Operational
      </div>
      <div class="legend-item active" data-legend="degraded" onclick="toggleLegend('degraded')">
        <span class="legend-dot degraded"></span> Degraded
      </div>
      <div class="legend-item active" data-legend="down" onclick="toggleLegend('down')">
        <span class="legend-dot down"></span> Down
      </div>
    </div>
  </div>
</div>

<div class="tooltip" id="tooltip">
  <div class="tt-time" id="ttTime"></div>
  <div class="tt-status" id="ttStatus"></div>
  <div class="tt-duration" id="ttDuration"></div>
</div>

<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <h3 id="modalTitle"></h3>
    <div class="modal-time" id="modalTime"></div>
    <div class="modal-status-badge" id="modalBadge"></div>
    <p id="modalDesc"></p>
    <button class="modal-close" onclick="closeModal()">Close</button>
  </div>
</div>
</body>
</html>

    <script src="./script.js"></script>
  </body>
</html>
